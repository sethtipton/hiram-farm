{
  "name": "hiram-farm-theme",
  "version": "1.0.0",
  "description": "Custom WordPress theme for the Hiram Farm site.",
  "author": "Seth Tipton",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Theme"
  ],
  "homepage": "https://github.com/sethtipton/hiram-farm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethtipton/hiram-farm.git"
  },
  "bugs": {
    "url": "https://github.com/sethtipton/hiram-farm/issues"
  },
  "devDependencies": {
    "@wordpress/scripts": "^19.2.2",
    "dir-archiver": "^1.1.1",
    "prettier": "^3.6.2",
    "rtlcss": "^3.5.0",
    "sass": "^1.93.2"
  },
  "rtlcssConfig": {
    "options": {
      "autoRename": false,
      "autoRenameStrict": false,
      "blacklist": {},
      "clean": true,
      "greedy": false,
      "processUrls": false,
      "stringMap": []
    },
    "plugins": [],
    "map": false
  },
  "scripts": {
    "watch": "sass --watch --style=expanded --source-map sass/style.scss:style.css",
    "build": "sass --style=expanded --no-source-map sass/style.scss:style.css && npm run build:rtl",
    "build:rtl": "rtlcss style.css style-rtl.css",
    "compile:css": "npm run build",
    "compile:rtl": "rtlcss style.css style-rtl.css",
    "lint:scss": "wp-scripts lint-style 'sass/**/*.scss'",
    "lint:js": "wp-scripts lint-js 'js/*.js'",
    "lint": "npm run lint:scss && npm run lint:js",
    "check": "npm run lint && npm run build",
    "format": "prettier --write \"*.{json,md}\"",
    "bundle": "dir-archiver --src . --dest ../hiram-farm-theme.zip --exclude .DS_Store .stylelintrc.json .eslintrc .editorconfig .git .gitattributes .github .gitignore .prettierignore .prettierrc.json README.md composer.json composer.lock node_modules vendor package-lock.json package.json .travis.yml phpcs.xml.dist sass style.css.map yarn.lock"
  }
}
